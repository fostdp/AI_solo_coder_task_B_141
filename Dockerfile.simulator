FROM python:3.11-slim

WORKDIR /app

COPY scripts/requirements-simulator.txt ./
RUN pip install --no-cache-dir -r requirements-simulator.txt

COPY scripts/simulator.py ./

ENTRYPOINT ["python", "-u", "simulator.py"]
CMD ["--udp-host", "backend", "--udp-port", "5005", "--interval", "1", "--event-probability", "0.1"]
